{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "incremental": false,
    "sourceMap": false,
    "declaration": false,
    "types": ["node"],
    "isolatedModules": false,
    "plugins": []
  },
  "include": [
    "lib/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".test-dist"
  ]
}
